# Copy this file to .env and fill in your values
# Never commit .env to git

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# A secret string shared between this backend and the app
# Make it long and random — change this to something unique
APP_SECRET=change-this-to-a-long-random-string

# Port (Railway sets this automatically — leave as 3000 for local dev)
PORT=3000
